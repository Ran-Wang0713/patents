{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "import_api.py",
      "use": "@vercel/python"
    },
    {
      "src": "network_visualization.py",
      "use": "@vercel/python"
    },
    {
      "src": "trend_prediction.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/import/(.*)",
      "dest": "import_api.py"
    },
    {
      "src": "/api/network/(.*)",
      "dest": "network_visualization.py"
    },
    {
      "src": "/api/trend/(.*)",
      "dest": "trend_prediction.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/",
      "dest": "index.html"
    }
  ]
}
